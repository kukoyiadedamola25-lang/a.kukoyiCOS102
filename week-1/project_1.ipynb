   "source": [
    "# Simple Interest Program\n",
    "\n",
    "P = float(input(\"Enter the Principal amount: \"))\n",
    "R = float(input(\"Enter the interest rate (%): \"))\n",
    "T = float(input(\"Entrer the time (years): \"))\n",
    "\n",
    "A = P * (1 + (R/100) * T)\n",
    "\n",
    "print(\"The total amount is:\", A) "
   ]
  }
